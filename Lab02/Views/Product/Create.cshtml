@model Lab02.Models.Product

<h2>Thêm sản phẩm</h2>
<form asp-action="Create" method="post">
   
    <div class="form-group">
        Id <input type="text" asp-for="Id" class="form-control" />
    </div>

    <div class="form-group">
        Name <input type="text" asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        Price <input type="text" asp-for="Price" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a href="/Product/Index" class="btn btn-secondary">Quay lại</a>
</form> 